    {
      "parameters": {
        "jsCode": "// Détermine s'il y a une réponse, et transporte les infos du lead\nconst items = $input.all();\nconst hasReply = items.some(i => i.json && i.json.id);\nconst lead = $('Scovi lead in').first().json.body;\nconst originalMessageId = $('Envoi J0').first().json.id;\nreturn [{ json: { ...lead, hasReply, originalMessageId } }];"
      },
